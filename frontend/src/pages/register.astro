---
import AppLayout from "@/layouts/AppLayout.astro";
import { AuthScreen } from "@/features/auth/AuthScreen";
---

<AppLayout title="Criar Conta | TodoList">
  <main class="auth-shell">
    <section class="auth-aside">
      <div class="auth-aside__badge">Novo acesso</div>
      <h2>Monte seu espaco e comece com uma lista que faz sentido.</h2>
      <p>
        Cadastro rapido, autenticacao direta e um board de tarefas pronto para acompanhar o seu fluxo.
      </p>
    </section>
    <AuthScreen client:load mode="register" />
  </main>
</AppLayout>
